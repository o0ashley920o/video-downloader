# Backend environment for FastAPI downloader
# Copy to backend/.env and edit values as needed.

# Optional DB settings
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=video_downloader

# Optional CORS override
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# yt-dlp network tuning
YTDLP_RETRIES=10
YTDLP_FRAGMENT_RETRIES=10
YTDLP_EXTRACTOR_RETRIES=3
YTDLP_SOCKET_TIMEOUT=30
YTDLP_CONCURRENT_FRAGMENTS=8
YTDLP_HTTP_CHUNK_SIZE=10485760

# User agent override (optional)
YTDLP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# Authenticated session options for sites that hide formats unless logged in.
# Use ONE of the following:

# 1) Preferred in devcontainer: export Netscape cookies.txt from your browser
#    and mount/copy it into this workspace.
#    Example path: /workspaces/video-downloader/backend/cookies.txt
# YTDLP_COOKIEFILE=/workspaces/video-downloader/backend/cookies.txt

# 2) Use browser profile directly (works only if browser profile exists in this environment)
#    Example: chrome, chromium, firefox, edge
# YTDLP_COOKIES_FROM_BROWSER=chrome
